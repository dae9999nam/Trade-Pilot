# Copy the relevant values into .env or export them before running Compose.
# Do not commit real account numbers, tokens, or trading credentials.

# Optional: after copying this to .env on the machine that starts Compose,
# plain `docker compose up --build -d` will include the live CREON override.
COMPOSE_PATH_SEPARATOR=:
COMPOSE_FILE=docker-compose.yml:docker-compose.creon-gateway.yml

BROKER_MODE=creon_gateway
CREON_GATEWAY_URL=http://WINDOWS_CREON_HOST_IP:8765
CREON_GATEWAY_TOKEN=replace-with-a-long-random-token
CREON_GATEWAY_TIMEOUT_SECONDS=10

CREON_ACCOUNT_NO=replace-with-account-number
CREON_GOODS_CODE=01

# Keep AUTO_EXECUTE=false until manual order review is proven end to end.
AUTO_EXECUTE=false
ALLOW_LIVE_TRADING=false
I_UNDERSTAND_LOSS_RISK=false
