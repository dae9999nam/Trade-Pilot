APP_ENV=development
DATABASE_URL=postgresql+psycopg://stock_pilot:stock_pilot@localhost:5432/stock_pilot
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# paper, creon, or creon_gateway
BROKER_MODE=paper
AUTO_EXECUTE=false
ALLOW_LIVE_TRADING=false
I_UNDERSTAND_LOSS_RISK=false

# Trading guardrails
MAX_ORDER_KRW=500000
MAX_POSITION_KRW=1000000
MAX_DAILY_LOSS_KRW=200000
MIN_DECISION_CONFIDENCE=0.62

# CREON Plus values are only used on Windows with 32-bit Python.
CREON_ACCOUNT_NO=
CREON_GOODS_CODE=01
CREON_ORDER_MARKET=KRX

# Used when BROKER_MODE=creon_gateway.
CREON_GATEWAY_URL=http://127.0.0.1:8765
CREON_GATEWAY_TOKEN=
CREON_GATEWAY_TIMEOUT_SECONDS=10

# Used only by the Windows native gateway.
GATEWAY_TOKEN=

# React Native app
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000
